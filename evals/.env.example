# pi-dynamic-workflows eval runner configuration
# Copy this to .env and customize, or pass CLI args directly.
# CLI args override .env values.
# All fields are provider-agnostic — use provider/model refs from your Pi registry.

# Model used to run the eval prompt (the "test model" — writes + executes workflow scripts)
# Example: PI_EVAL_TEST_MODEL=provider/model-name
PI_EVAL_TEST_MODEL=

# Model used to evaluate test output (the "judge" — reads output, scores criteria)
# Example: PI_EVAL_JUDGE_MODEL=provider/judge-model
PI_EVAL_JUDGE_MODEL=

# Model refs injected into eval prompts so generated workflow scripts use explicit provider/model refs.
# These may all be the same model if you want cheap smoke tests.
# Example: PI_EVAL_LIGHT_MODEL=provider/fast-model
PI_EVAL_LIGHT_MODEL=
PI_EVAL_MEDIUM_MODEL=
PI_EVAL_HEAVY_MODEL=

# Per-eval timeout in seconds (default 300)
PI_EVAL_TIMEOUT=300

# Workflow policy JSON (optional). Controls max concurrency, hard abort grace period, mailbox pause timeout, etc.
# Example: PI_EVAL_POLICY='{"maxConcurrency":4,"hardAbortGraceMs":2000,"hostTools":"none"}'
PI_EVAL_POLICY=

# Workflow extension path (default: ../extensions/workflow.ts relative to evals/ dir)
# PI_EVAL_WORKFLOW_EXT=/path/to/extensions/workflow.ts

# Report output path (default: results/report-<timestamp>.json)
# PI_EVAL_REPORT=results/report.json

# Max concurrent subagents within each workflow
PI_EVAL_MAX_CONCURRENCY=4

# Judge model timeout in seconds (default 120)
PI_EVAL_JUDGE_TIMEOUT=120